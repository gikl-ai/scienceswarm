# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
.omc/
.superpowers/
.venv/
.ruff_cache/
playwright-report/
test-results/
vitest-results/
bench-result.json
bench-stdout.log
.playwright-mcp/
.gstack/
.uat/
.scienceswarm/
.codex/skills/
.claude/skills/
.claude/worktrees/
.claude/scheduled_tasks.lock
.playwright-mcp/
.remember/
.context/

# local main-edit bypass sentinel (PreToolUse hook in .claude/settings.json)
.claude/allow-main-edits
