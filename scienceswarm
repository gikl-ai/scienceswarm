#!/usr/bin/env bash
set -euo pipefail

resolve_script_path() {
  local source="${BASH_SOURCE[0]:-$0}"
  local dir=""

  while [ -L "$source" ]; do
    dir="$(cd -P "$(dirname "$source")" && pwd)"
    source="$(readlink "$source")"
    case "$source" in
      /*) ;;
      *) source="$dir/$source" ;;
    esac
  done

  printf '%s\n' "$source"
}

SCRIPT_PATH="$(resolve_script_path)"
REPO_ROOT="$(cd -P "$(dirname "$SCRIPT_PATH")" && pwd)"

usage() {
  cat <<'EOF'
Usage:
  scienceswarm <command> [args]

Commands:
  install    Run install.sh from the ScienceSwarm checkout
  start      Start ScienceSwarm, then open the dashboard when ready
  open       Open the running local dashboard in Chrome or a named browser
  stop       Stop the managed ScienceSwarm launcher and local runtime helpers
  restart    Stop the current launcher, start it again, then open the dashboard
  status     Show the current local runtime status
  doctor     Run npm run doctor
  reset      Run npm run setup:reset
  help       Show this help

Examples:
  scienceswarm start
  scienceswarm start --no-open
  scienceswarm start --browser safari
  scienceswarm open
  scienceswarm open chrome
  scienceswarm open safari setup
  scienceswarm open setup
  scienceswarm restart --browser chrome
  scienceswarm status
  scienceswarm reset -- --keep-telegram-bot

Advanced workflows such as `dev:worktree`, tests, and build commands stay on
their existing `npm run ...` entrypoints.
EOF
}

note() {
  printf '%s\n' "$*"
}

die() {
  printf 'error: %s\n' "$*" >&2
  exit 1
}

is_truthy() {
  case "$(printf '%s' "${1:-}" | tr '[:upper:]' '[:lower:]')" in
    true|1|yes|on)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

load_repo_env() {
  # shellcheck source=scripts/openclaw-env.sh
  source "$REPO_ROOT/scripts/openclaw-env.sh"

  if [ -f "$REPO_ROOT/.env" ]; then
    local existing_env=""
    existing_env="$(mktemp)"
    # Snapshot after OpenClaw defaults are loaded so .env cannot override
    # runtime-resolved OpenClaw values or explicit caller env.
    env -0 > "$existing_env"
    set -a
    # shellcheck disable=SC1091
    source "$REPO_ROOT/.env"
    set +a
    while IFS='=' read -r -d '' key value; do
      case "$key" in
        ''|*[!A-Za-z0-9_]*|[0-9]*)
          continue
          ;;
      esac
      export "$key=$value"
    done < "$existing_env"
    rm -f "$existing_env"
  fi

  if command -v npx >/dev/null 2>&1 && [ -f "$REPO_ROOT/scripts/print-port.ts" ]; then
    eval "$(
      cd "$REPO_ROOT" && npx tsx scripts/print-port.ts env 2>/dev/null || true
    )"
  fi

  : "${FRONTEND_HOST:=127.0.0.1}"
  : "${FRONTEND_PORT:=3001}"
  : "${FRONTEND_PUBLIC_HOST:=$FRONTEND_HOST}"
  : "${FRONTEND_USE_HTTPS:=false}"
  DATA_ROOT="${SCIENCESWARM_DIR:-$HOME/.scienceswarm}"
  RUN_ROOT="$DATA_ROOT/run"
  LAUNCHER_PID_FILE="$RUN_ROOT/launcher.pid"
  OPENHANDS_CONTAINER_FILE="$RUN_ROOT/openhands.cid"

  if [ -n "${OPENCLAW_PROFILE:-}" ] && [[ "${OPENCLAW_PROFILE}" =~ [^[:space:]] ]]; then
    OPENCLAW_MODE="profile"
  else
    OPENCLAW_MODE="state-dir"
  fi
  OPENCLAW_GATEWAY_PID_FILE="$(openclaw_gateway_pid_file)"
}

read_pid_file() {
  local path="$1"
  local raw=""

  [ -f "$path" ] || return 1
  raw=$(tr -d '[:space:]' < "$path" 2>/dev/null || true)
  if ! [[ "$raw" =~ ^[0-9]+$ ]] || [ "$raw" -le 0 ]; then
    rm -f "$path"
    return 1
  fi
  if ! kill -0 "$raw" 2>/dev/null; then
    rm -f "$path"
    return 1
  fi
  printf '%s\n' "$raw"
}

read_text_file() {
  local path="$1"
  local raw=""

  [ -f "$path" ] || return 1
  raw=$(tr -d '[:space:]' < "$path" 2>/dev/null || true)
  [ -n "$raw" ] || return 1
  printf '%s\n' "$raw"
}

pid_command_contains() {
  local pid="$1"
  local needle="$2"
  local command=""

  command=$(ps -o command= -p "$pid" 2>/dev/null || true)
  case "$command" in
    *"$needle"*)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

pid_stat_contains() {
  local pid="$1"
  local needle="$2"
  local stat=""

  stat=$(ps -o stat= -p "$pid" 2>/dev/null | tr -d '[:space:]' || true)
  case "$stat" in
    *"$needle"*)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

read_launcher_pid_file() {
  local pid=""

  pid=$(read_pid_file "$LAUNCHER_PID_FILE" || true)
  [ -n "$pid" ] || return 1
  if ! pid_command_contains "$pid" "start.sh"; then
    rm -f "$LAUNCHER_PID_FILE"
    return 1
  fi
  printf '%s\n' "$pid"
}

read_openclaw_gateway_pid() {
  local pid=""

  pid=$(read_pid_file "$OPENCLAW_GATEWAY_PID_FILE" || true)
  [ -n "$pid" ] || return 1
  if ! pid_command_contains "$pid" "openclaw"; then
    rm -f "$OPENCLAW_GATEWAY_PID_FILE"
    return 1
  fi
  printf '%s\n' "$pid"
}

listener_pid_for_port() {
  local pid=""

  if ! command -v lsof >/dev/null 2>&1; then
    return 1
  fi

  pid=$(lsof -tiTCP:"$1" -sTCP:LISTEN 2>/dev/null | head -n 1 || true)
  [ -n "$pid" ] || return 1
  printf '%s\n' "$pid"
}

frontend_configured_scheme() {
  if is_truthy "${FRONTEND_USE_HTTPS:-false}"; then
    printf '%s\n' "https"
  else
    printf '%s\n' "http"
  fi
}

frontend_probe_host() {
  case "${FRONTEND_HOST:-127.0.0.1}" in
    ""|localhost|0.0.0.0|"::")
      printf '%s\n' "127.0.0.1"
      ;;
    "::1"|"[::1]")
      printf '%s\n' "[::1]"
      ;;
    *)
      printf '%s\n' "$FRONTEND_HOST"
      ;;
  esac
}

frontend_browser_host() {
  local host="${FRONTEND_PUBLIC_HOST:-${FRONTEND_HOST:-127.0.0.1}}"

  case "$host" in
    ""|localhost|0.0.0.0|"::")
      printf '%s\n' "127.0.0.1"
      ;;
    "::1"|"[::1]")
      printf '%s\n' "[::1]"
      ;;
    *)
      printf '%s\n' "$host"
      ;;
  esac
}

normalize_frontend_path() {
  case "${1:-dashboard}" in
    ""|dashboard|project|dashboard/project|/dashboard|/dashboard/project)
      printf '%s\n' "/dashboard/project"
      ;;
    setup|/setup)
      printf '%s\n' "/setup"
      ;;
    /*)
      printf '%s\n' "$1"
      ;;
    *)
      printf '/%s\n' "$1"
      ;;
  esac
}

frontend_url() {
  local scheme="$1"
  local target_path
  target_path="$(normalize_frontend_path "${2:-dashboard}")"

  printf '%s://%s:%s%s\n' "$scheme" "$(frontend_browser_host)" "$FRONTEND_PORT" "$target_path"
}

normalize_browser_name() {
  local raw
  raw="$(printf '%s' "${1:-}" | tr '[:upper:]' '[:lower:]')"

  case "$raw" in
    ""|default|system)
      printf '%s\n' ""
      ;;
    chrome|google|google-chrome|"google chrome")
      printf '%s\n' "Google Chrome"
      ;;
    safari)
      printf '%s\n' "Safari"
      ;;
    firefox|mozilla|"mozilla firefox")
      printf '%s\n' "Firefox"
      ;;
    edge|msedge|"microsoft edge")
      printf '%s\n' "Microsoft Edge"
      ;;
    brave|"brave browser")
      printf '%s\n' "Brave Browser"
      ;;
    arc)
      printf '%s\n' "Arc"
      ;;
    *)
      printf '%s\n' "$1"
      ;;
  esac
}

is_browser_token() {
  local raw
  raw="$(printf '%s' "${1:-}" | tr '[:upper:]' '[:lower:]')"

  case "$raw" in
    default|system|chrome|google|google-chrome|"google chrome"|safari|firefox|mozilla|"mozilla firefox"|edge|msedge|"microsoft edge"|brave|"brave browser"|arc)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

browser_cli_candidates() {
  local app="$1"

  case "$(printf '%s' "$app" | tr '[:upper:]' '[:lower:]')" in
    "google chrome")
      printf '%s\n' google-chrome google-chrome-stable chrome chromium chromium-browser
      ;;
    safari)
      printf '%s\n' safari
      ;;
    firefox)
      printf '%s\n' firefox
      ;;
    "microsoft edge")
      printf '%s\n' microsoft-edge microsoft-edge-stable msedge
      ;;
    "brave browser")
      printf '%s\n' brave-browser brave
      ;;
    arc)
      printf '%s\n' arc
      ;;
  esac
}

open_with_browser_app() {
  local app="$1"
  local url="$2"
  local cmd=""

  if [ -n "$app" ] && command -v open >/dev/null 2>&1 && open -a "$app" "$url" >/dev/null 2>&1; then
    return 0
  fi

  while IFS= read -r cmd; do
    [ -n "$cmd" ] || continue
    if command -v "$cmd" >/dev/null 2>&1; then
      "$cmd" "$url" >/dev/null 2>&1 &
      return 0
    fi
  done < <(browser_cli_candidates "$app")

  return 1
}

wsl_browser_url() {
  local url="$1"

  case "$url" in
    http://127.0.0.1:*|https://127.0.0.1:*)
      printf '%s\n' "${url/127.0.0.1/localhost}"
      ;;
    *)
      printf '%s\n' "$url"
      ;;
  esac
}

open_with_system_default() {
  local url="$1"

  if command -v open >/dev/null 2>&1 && open "$url" >/dev/null 2>&1; then
    return 0
  fi
  if command -v xdg-open >/dev/null 2>&1 && xdg-open "$url" >/dev/null 2>&1; then
    return 0
  fi
  if command -v wslview >/dev/null 2>&1 && wslview "$(wsl_browser_url "$url")" >/dev/null 2>&1; then
    return 0
  fi

  return 1
}

open_frontend_url() {
  local url="$1"
  local requested_browser="${2:-}"
  local browser_app=""

  if [ -n "$requested_browser" ]; then
    browser_app="$(normalize_browser_name "$requested_browser")"
    if [ -z "$browser_app" ]; then
      note "Opening $url in the system default browser"
      open_with_system_default "$url"
      return $?
    fi

    note "Opening $url in $browser_app"
    open_with_browser_app "$browser_app" "$url"
    return $?
  fi

  browser_app="$(normalize_browser_name chrome)"
  note "Opening $url in $browser_app"
  if open_with_browser_app "$browser_app" "$url"; then
    return 0
  fi

  note "Chrome was not available; trying the system default browser."
  open_with_system_default "$url"
}

probe_frontend_scheme() {
  local scheme="$1"
  local url

  url="${scheme}://$(frontend_probe_host):${FRONTEND_PORT}/api/health"
  if [ "$scheme" = "https" ]; then
    curl -kfsS --max-time 2 "$url" >/dev/null 2>&1
  else
    curl -fsS --max-time 2 "$url" >/dev/null 2>&1
  fi
}

detect_frontend_health_scheme() {
  FRONTEND_HEALTH_SCHEME=""

  if is_truthy "${FRONTEND_USE_HTTPS:-false}"; then
    if probe_frontend_scheme "https"; then
      FRONTEND_HEALTH_SCHEME="https"
      return 0
    fi
    if probe_frontend_scheme "http"; then
      FRONTEND_HEALTH_SCHEME="http"
      return 0
    fi
  else
    if probe_frontend_scheme "http"; then
      FRONTEND_HEALTH_SCHEME="http"
      return 0
    fi
    if probe_frontend_scheme "https"; then
      FRONTEND_HEALTH_SCHEME="https"
      return 0
    fi
  fi

  return 1
}

docker_container_running_state() {
  local container_id="$1"
  local raw=""

  if ! command -v docker >/dev/null 2>&1; then
    return 1
  fi

  raw=$(docker inspect -f '{{.State.Running}}' "$container_id" 2>/dev/null | tr -d '[:space:]' || true)
  case "$raw" in
    true|false)
      printf '%s\n' "$raw"
      ;;
    *)
      return 1
      ;;
  esac
}

wait_for_pid_exit() {
  local pid="$1"
  local attempts="${2:-20}"

  while [ "$attempts" -gt 0 ]; do
    if ! kill -0 "$pid" 2>/dev/null; then
      return 0
    fi
    sleep 1
    attempts=$((attempts - 1))
  done

  return 1
}

kill_pid_group() {
  local pid="$1"
  local label="$2"

  if kill -- -"$pid" 2>/dev/null; then
    note "Stopping $label (process group $pid)..."
  elif kill "$pid" 2>/dev/null; then
    note "Stopping $label (pid $pid)..."
  else
    return 1
  fi

  if wait_for_pid_exit "$pid" 15; then
    return 0
  fi

  note "$label is still running; forcing it down."
  kill -KILL -- -"$pid" 2>/dev/null || kill -KILL "$pid" 2>/dev/null || true
  wait_for_pid_exit "$pid" 5 || true
  return 0
}

stop_openhands_container() {
  local container_id=""

  if ! command -v docker >/dev/null 2>&1; then
    return 0
  fi

  container_id=$(read_text_file "$OPENHANDS_CONTAINER_FILE" || true)
  if [ -z "$container_id" ]; then
    rm -f "$OPENHANDS_CONTAINER_FILE"
    return 0
  fi

  note "Stopping OpenHands container scienceswarm-agent..."
  docker rm -f "$container_id" >/dev/null 2>&1 || docker rm -f scienceswarm-agent >/dev/null 2>&1 || true
  rm -f "$OPENHANDS_CONTAINER_FILE"
}

stop_openclaw_gateway() {
  local pid=""

  pid=$(read_openclaw_gateway_pid || true)
  [ -n "$pid" ] || return 0
  kill_pid_group "$pid" "OpenClaw gateway" || true
  rm -f "$OPENCLAW_GATEWAY_PID_FILE"
}

cmd_install() {
  cd "$REPO_ROOT"
  exec ./install.sh "$@"
}

cmd_start() {
  cd "$REPO_ROOT"
  exec ./start.sh "$@"
}

print_restart_usage() {
  note "Usage: scienceswarm restart [--no-open] [--browser <name>] [--open <dashboard|setup|/path>]"
  note "Stops the managed local runtime, starts a fresh foreground server log, then opens the dashboard when healthy."
  note "Use --no-open for headless runs. Use scienceswarm open manually if the browser does not appear."
}

print_open_usage() {
  note "Usage: scienceswarm open [browser] [dashboard|setup|/path]"
  note "       scienceswarm open [dashboard|setup|/path] --browser <browser>"
  note "Examples: scienceswarm open, scienceswarm open safari setup, scienceswarm open --browser firefox /dashboard/project"
}

cmd_open() {
  local requested_browser=""
  local target_path=""
  local url=""

  for arg in "$@"; do
    case "$arg" in
      -h|--help)
        print_open_usage
        return 0
        ;;
    esac
  done

  load_repo_env

  while [ "$#" -gt 0 ]; do
    case "$1" in
      -b|--browser)
        shift
        [ "$#" -gt 0 ] || die "missing browser name after --browser"
        requested_browser="$1"
        ;;
      --browser=*)
        requested_browser="${1#--browser=}"
        ;;
      -h|--help)
        print_open_usage
        return 0
        ;;
      *)
        if [ -z "$requested_browser" ] && is_browser_token "$1"; then
          requested_browser="$1"
        elif [ -z "$target_path" ]; then
          target_path="$1"
        else
          die "unexpected scienceswarm open argument '$1'"
        fi
        ;;
    esac
    shift
  done

  target_path="$(normalize_frontend_path "${target_path:-dashboard}")"

  if ! detect_frontend_health_scheme; then
    die "frontend is unreachable on $(frontend_probe_host):$FRONTEND_PORT. Run scienceswarm start, then retry."
  fi

  url="$(frontend_url "$FRONTEND_HEALTH_SCHEME" "$target_path")"
  if open_frontend_url "$url" "$requested_browser"; then
    note "If the page does not load, run scienceswarm status and use the exact Open URL it prints."
    return 0
  fi

  die "could not launch a browser automatically. Open this URL manually: $url"
}

cmd_stop() {
  local launcher_pid=""
  local listener_pid=""

  load_repo_env

  launcher_pid=$(read_launcher_pid_file || true)
  if [ -n "$launcher_pid" ]; then
    kill_pid_group "$launcher_pid" "ScienceSwarm launcher" || true
    rm -f "$LAUNCHER_PID_FILE"
  else
    listener_pid=$(listener_pid_for_port "$FRONTEND_PORT" || true)
    if [ -n "$listener_pid" ]; then
      die "frontend listener detected on $FRONTEND_HOST:$FRONTEND_PORT (pid $listener_pid), but no managed launcher pid file exists. Stop that process manually, then rerun scienceswarm start."
    fi
    note "ScienceSwarm launcher is not running."
  fi

  stop_openhands_container
  stop_openclaw_gateway
}

cmd_restart() {
  local restart_args=()
  local scheme=""
  local option=""

  while [ "$#" -gt 0 ]; do
    case "$1" in
      -h|--help)
        print_restart_usage
        return 0
        ;;
      --no-open)
        restart_args+=("$1")
        ;;
      --browser=*|--open=*)
        option="${1%%=*}"
        [ -n "${1#*=}" ] || die "missing value after $option"
        restart_args+=("$1")
        ;;
      --browser|--open)
        option="$1"
        restart_args+=("$1")
        shift
        [ "$#" -gt 0 ] || die "missing value after $option"
        case "$1" in
          --*)
            die "missing value after $option"
            ;;
        esac
        restart_args+=("$1")
        ;;
      *)
        die "unknown restart option '$1'. Run scienceswarm restart --help."
        ;;
    esac
    shift
  done
  set -- "${restart_args[@]}"

  load_repo_env
  scheme="$(frontend_configured_scheme)"

  note "ScienceSwarm restart"
  note ""
  note "What this command does:"
  note "  1. Stops the old local ScienceSwarm runtime."
  note "  2. Starts a fresh local server in this same terminal."
  note "  3. Opens the dashboard automatically after the frontend health check passes."
  note "  4. Leaves this terminal attached as the live server log."
  note ""
  note "If the browser does not appear:"
  note "  Open dashboard manually: ./scienceswarm open"
  note "  Open setup manually:     ./scienceswarm open setup"
  note "  Browser choice:          ./scienceswarm open safari    # or chrome, firefox, edge, brave, arc"
  note "  Disable auto-open:       ./scienceswarm restart --no-open"
  note ""
  note "Direct URLs for this run:"
  note "  Dashboard: $(frontend_url "$scheme" dashboard)"
  note "  Setup:     $(frontend_url "$scheme" setup)"
  if [ "$scheme" = "https" ]; then
    note "  Protocol:  use https:// only on this port; http:// will fail."
    note "  Safari:    self-signed local HTTPS can fail in Safari. Prefer ./scienceswarm open chrome or set FRONTEND_USE_HTTPS=false."
  else
    note "  Protocol:  use http:// only on this port; https:// will fail."
  fi
  note ""
  cmd_stop
  note "Restarting ScienceSwarm..."
  cmd_start "$@"
}

cmd_status() {
  local launcher_pid=""
  local gateway_pid=""
  local listener_pid=""
  local openhands_running="stopped"
  local frontend_status="stopped"
  local frontend_health="unreachable"
  local frontend_scheme=""
  local frontend_preferred_scheme=""
  local gateway_status="stopped"
  local openhands_container_id=""
  local openhands_state=""

  load_repo_env

  launcher_pid=$(read_launcher_pid_file || true)
  if [ -n "$launcher_pid" ]; then
    if pid_stat_contains "$launcher_pid" "T"; then
      frontend_status="suspended (launcher pid $launcher_pid)"
    else
      frontend_status="running (launcher pid $launcher_pid)"
    fi
  else
    listener_pid=$(listener_pid_for_port "$FRONTEND_PORT" || true)
    if [ -n "$listener_pid" ]; then
      frontend_status="listener active on $FRONTEND_HOST:$FRONTEND_PORT (pid $listener_pid, unmanaged)"
    fi
  fi

  openhands_container_id=$(read_text_file "$OPENHANDS_CONTAINER_FILE" || true)
  if [ -n "$openhands_container_id" ]; then
    openhands_state=$(docker_container_running_state "$openhands_container_id" || true)
    case "$openhands_state" in
      true)
        openhands_running="running"
        ;;
      false)
        openhands_running="stopped (container present)"
        ;;
      *)
      rm -f "$OPENHANDS_CONTAINER_FILE"
        ;;
    esac
  fi

  gateway_pid=$(read_openclaw_gateway_pid || true)
  if [ -n "$gateway_pid" ]; then
    gateway_status="running (pid $gateway_pid)"
  fi

  frontend_preferred_scheme="$(frontend_configured_scheme)"
  if detect_frontend_health_scheme; then
    frontend_scheme="$FRONTEND_HEALTH_SCHEME"
    frontend_health="ok ($frontend_scheme)"
  else
    frontend_scheme="$frontend_preferred_scheme"
  fi

  note "ScienceSwarm status"
  note "  Repo root: $REPO_ROOT"
  note "  Data root: $DATA_ROOT"
  note "  Frontend: $frontend_status"
  note "  Frontend health: $frontend_health"
  if [ "$frontend_health" = "unreachable" ]; then
    note "  Open: unavailable until the frontend is healthy"
    note "  Expected URL: $(frontend_url "$frontend_scheme" dashboard)"
    note "  Next step: run scienceswarm start"
  else
    note "  Open: $(frontend_url "$frontend_scheme" dashboard)"
    note "  Setup: $(frontend_url "$frontend_scheme" setup)"
    note "  Next step: run scienceswarm open"
    if [ "$frontend_scheme" != "$frontend_preferred_scheme" ]; then
      note "  Warning: FRONTEND_USE_HTTPS=${FRONTEND_USE_HTTPS:-false}, but $frontend_scheme answered on this port. Use the Open URL above."
    elif [ "$frontend_scheme" = "https" ]; then
      note "  Note: this port is serving HTTPS; http:// URLs on this port will fail. HTTPS is opt-in because self-signed local certs are not trusted by every browser."
    else
      note "  Note: this port is serving HTTP; https:// URLs on this port will fail."
    fi
    note "  Browser: scienceswarm open uses Chrome by default; pass a browser name such as 'safari' or 'firefox' to override."
  fi
  note "  OpenHands: $openhands_running"
  note "  OpenClaw gateway: $gateway_status"
  note "  OpenClaw mode: $OPENCLAW_MODE"
}

cmd_doctor() {
  cd "$REPO_ROOT"
  exec npm run doctor -- "$@"
}

cmd_reset() {
  cd "$REPO_ROOT"
  exec npm run setup:reset -- "$@"
}

COMMAND="${1:-help}"
if [ "$#" -gt 0 ]; then
  shift
fi

case "$COMMAND" in
  install)
    cmd_install "$@"
    ;;
  start)
    cmd_start "$@"
    ;;
  open)
    cmd_open "$@"
    ;;
  stop)
    cmd_stop "$@"
    ;;
  restart)
    cmd_restart "$@"
    ;;
  status)
    cmd_status "$@"
    ;;
  doctor)
    cmd_doctor "$@"
    ;;
  reset)
    cmd_reset "$@"
    ;;
  help|-h|--help)
    usage
    ;;
  *)
    usage >&2
    die "unknown command '$COMMAND'"
    ;;
esac
