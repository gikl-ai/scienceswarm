# Ports (all optional; override any of these to relocate services):
# FRONTEND_HOST=127.0.0.1  Bind loopback by default; use 0.0.0.0 only behind auth/proxy
# FRONTEND_PUBLIC_HOST=127.0.0.1  External bind host for local-only route guard
# FRONTEND_USE_HTTPS=true  Prefer HTTPS for local-first Safari compatibility
# FRONTEND_HTTPS_KEY=
# FRONTEND_HTTPS_CERT=
# FRONTEND_PORT=3001       ScienceSwarm Next.js app
# OPENHANDS_PORT=3000      OpenHands agent container
# OPENCLAW_URL=ws://127.0.0.1:18789/ws
# OPENCLAW_PORT=18789      (default lives in src/lib/config/ports.ts)
# NANOCLAW_PORT=3002
# OLLAMA_URL=http://localhost:11434

# Local-first setup
# The default path uses Ollama + gemma4:latest. Settings can later switch the
# saved local model to another Ollama tag such as gemma4:26b. OpenAI is
# optional cloud fallback, not required for first-run local setup.
OPENAI_API_KEY=
SCIENCESWARM_USER_HANDLE=
GIT_USER_EMAIL=
TELEGRAM_PHONE=

# Optional — model selection
LLM_PROVIDER=local
OLLAMA_MODEL=gemma4:latest
# OpenHands local execution requires a larger context than simple chat.
# Defaults to 32768; values below 22000 are reported as misconfigured.
OLLAMA_CONTEXT_LENGTH=32768
# Cloud-only model override. Leave blank for local mode; OpenHands derives
# `openai/<OLLAMA_MODEL>` from the local runtime contract.
LLM_MODEL=
OPENAI_WEB_SEARCH_MODEL=

# Optional — runtime host policy and API-key fallback
# OpenClaw stays the local-first default. Claude Code, Codex, and Gemini CLI use
# your native CLI login and are allowed only when the project composer policy is
# moved from local-only to cloud-ok. OpenHands execution requires execution-ok.
# Set SCIENCESWARM_STRICT_LOCAL_ONLY=true to force local LLM behavior even when
# cloud keys are present.
SCIENCESWARM_STRICT_LOCAL_ONLY=
# API-key runtime adapters read these when explicitly configured. Leave blank if
# you use subscription-native CLI hosts instead of .env-backed provider calls.
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=
GOOGLE_API_KEY=
VERTEX_AI_API_KEY=
VERTEX_AI_PROJECT=
VERTEX_AI_LOCATION=

# Optional — OpenHands agent
# Default: http://localhost:3000
OPENHANDS_URL=http://localhost:3000
# Runtime image is pinned by digest by default because the container mounts
# docker.sock. This default tracks an upstream OpenHands main snapshot;
# override only after reviewing the replacement image.
# OPENHANDS_IMAGE=docker.openhands.dev/openhands/openhands@sha256:53ff46b778a4e2f5e8013adc12e347e421bacc9239e2f0482989aec391934487
# Optional evidence file override for `npm run smoke:local -- --verify-openhands-local`.
# Default: $SCIENCESWARM_DIR/runtime/openhands-local-smoke.json
# SCIENCESWARM_OPENHANDS_LOCAL_EVIDENCE_PATH=

# Agent backend — which claw agent to use for chat (openclaw, nanoclaw, hermes, none)
AGENT_BACKEND=none
# Agent HTTP endpoint — works with any agent running anywhere
AGENT_URL=
AGENT_API_KEY=

# Legacy — OpenClaw gateway (used as fallback if AGENT_URL is not set).
# Leave OPENCLAW_URL empty to let the client derive ws://127.0.0.1:<OPENCLAW_PORT>/ws
# from the port default in src/lib/config/ports.ts.
OPENCLAW_URL=
OPENCLAW_TOKEN=
OPENCLAW_INTERNAL_API_KEY=

# OpenClaw state location:
#   Default (state-dir mode): $SCIENCESWARM_DIR/openclaw/ — fully isolated,
#   no ~/.openclaw-* sibling dir created. Set OPENCLAW_PROFILE=<name> below
#   to use an existing OpenClaw profile of yours instead (power-user opt-in).
# OPENCLAW_PROFILE=

# Product-managed — Reasoning Audit uses the built-in ScienceSwarm hosted service.
# No URL or bearer token is required in local `.env`.
STRUCTURED_CRITIQUE_TIMEOUT_MS=1800000

# Optional — scientific database wrappers
# PubMed works without NCBI_API_KEY, but the key raises NCBI E-utilities
# rate limits from 3 req/s to 10 req/s. Materials Project and Semantic
# Scholar require their keys. Crossref and OpenAlex mailto values opt into
# polite pools and identify ScienceSwarm traffic.
NCBI_API_KEY=
MATERIALS_PROJECT_API_KEY=
SEMANTIC_SCHOLAR_API_KEY=
CROSSREF_MAILTO=
OPENALEX_MAILTO=

# Audit-revise sandbox HTTP gateway (docker-compose openhands service).
# The scienceswarm/sandbox:latest image ships a tiny `gbrain` HTTP wrapper
# that calls back into this Next.js server via SCIENCESWARM_HOST_URL with a
# shared token. If SCIENCESWARM_SANDBOX_TOKEN is unset, every
# /api/brain/{page,link,file-upload} POST refuses the request with 503 —
# there is no anonymous write path. The sandbox must call back through this
# server instead of opening its own direct gbrain connection.
SCIENCESWARM_SANDBOX_TOKEN=
# Override only if the sandbox reaches a different host (e.g. CI or a
# remote compose stack). Defaults to http://host.docker.internal:3001.
SCIENCESWARM_HOST_URL=

# Current OpenHands resolves the sandbox image via these two vars (NOT the
# legacy SANDBOX_BASE_CONTAINER_IMAGE that 1.5 used). Build the custom
# image once with ./scripts/build-sandbox.sh, then set both here.
# When unset, OH falls back to the stock agent-server image.
AGENT_SERVER_IMAGE_REPOSITORY=
AGENT_SERVER_IMAGE_TAG=

# Optional — Integrations
TELEGRAM_BOT_TOKEN=
# Auto-populated after your first successful Telegram login. Lets later
# onboarding reruns reuse the same bot without re-running BotFather.
TELEGRAM_USER_ID=
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
DISCORD_BOT_TOKEN=
TWITTER_BEARER_TOKEN=
JIRA_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Adjust if FRONTEND_PORT is overridden.
GOOGLE_REDIRECT_URI=http://localhost:3001/api/drive?action=callback
GOOGLE_CALENDAR_CREDENTIALS=
GMAIL_CREDENTIALS=
ZOTERO_API_KEY=
ZOTERO_USER_ID=

# Authentication (NextAuth v5)
# Auto-generated on first run if empty; or generate with: openssl rand -hex 32
NEXTAUTH_SECRET=
# Adjust if FRONTEND_PORT is overridden.
NEXTAUTH_URL=http://localhost:3001
GITHUB_ID=
GITHUB_SECRET=

# Database (Prisma + SQLite)
DATABASE_URL="file:./dev.db"

# Optional — local app data (supports ~/... expansion)
# Default when unset: ~/.scienceswarm
# Uncomment and set to a real absolute path only if you want a custom location
# (e.g. to run multiple installs side by side).
# SCIENCESWARM_DIR=~/.scienceswarm-alt

# Optional — brain override (defaults to SCIENCESWARM_DIR/brain or ~/.scienceswarm/brain)
# BRAIN_ROOT=/path/to/custom-brain
# Optional fallback path to a local calendar JSON export for meeting prep
# BRAIN_CALENDAR_PATH=/path/to/calendar-events.json

# Brain storage (PGLite — zero config, works out of the box)
# BRAIN_PGLITE_PATH=~/.scienceswarm/brain/brain.pglite   # default if unset: <BRAIN_ROOT>/brain.pglite

# Optional — background brain runners.
# ENABLE_RADAR_RUNNER=true
# SCIENCESWARM_RADAR_INTERVAL_MINUTES=30
# Dream Cycle is on by default; set false to disable the nightly sidecar.
# ENABLE_DREAM_RUNNER=false
# SCIENCESWARM_DREAM_CHECK_INTERVAL_MINUTES=1

# Embedding / query expansion keys (optional)
# GBRAIN_OPENAI_KEY=sk-...
# GBRAIN_ANTHROPIC_KEY=sk-...  (optional: enables query expansion)
