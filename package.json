{
  "name": "scienceswarm",
  "version": "0.1.0",
  "private": true,
  "description": "ScienceSwarm \u2014 local-first research workspace. OpenClaw (manager agent) + OpenHands (execution agent) + gbrain (knowledge layer).",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gikl-ai/scienceswarm.git"
  },
  "homepage": "https://github.com/gikl-ai/scienceswarm#readme",
  "bugs": {
    "url": "https://github.com/gikl-ai/scienceswarm/issues"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "FRONTEND_HOST=${FRONTEND_HOST:-127.0.0.1} next dev -H ${FRONTEND_HOST:-127.0.0.1} -p $(npx tsx scripts/print-port.ts frontend)",
    "build": "next build",
    "start": "./start.sh",
    "lint": "eslint",
    "test": "vitest run",
    "test:fast": "vitest run --config vitest.fast.config.ts",
    "test:related": "node scripts/run-related-tests.mjs",
    "test:bench": "vitest bench --run",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit --pretty false -p tsconfig.typecheck.json",
    "python:quality": "./scripts/python-quality.sh",
    "doctor": "npx tsx scripts/doctor.ts",
    "smoke:local": "NODE_OPTIONS=--preserve-symlinks npx tsx scripts/smoke-local.ts",
    "connect-gbrain": "NODE_OPTIONS=--preserve-symlinks npx tsx scripts/connect-gbrain.ts",
    "install:gbrain": "NODE_OPTIONS=--preserve-symlinks npx tsx scripts/install-gbrain.ts",
    "setup:reset": "NODE_OPTIONS=--preserve-symlinks npx tsx scripts/reset-onboarding.ts",
    "migrate:chat-threads-openclaw": "NODE_OPTIONS=--preserve-symlinks npx tsx scripts/migrate-chat-threads-openclaw.ts",
    "bench:chat-hi": "NODE_OPTIONS=--preserve-symlinks npx tsx scripts/benchmark-chat-hi.ts",
    "import-pdfs": "npx tsx scripts/import-pdfs.ts",
    "radar:run": "NODE_OPTIONS=--preserve-symlinks npx tsx scripts/run-research-radar.ts",
    "dream:run": "NODE_OPTIONS=--preserve-symlinks npx tsx scripts/run-dream-cycle.ts",
    "quality": "npm run test && npm run lint && npm run typecheck && npm run build",
    "design:drift": "node --experimental-strip-types scripts/check-design-drift.ts",
    "design:drift:strict": "node --experimental-strip-types scripts/check-design-drift.ts --error"
  },
  "dependencies": {
    "@capacitor/camera": "^8.0.2",
    "@capacitor/cli": "^8.3.0",
    "@capacitor/core": "^8.3.0",
    "@capacitor/haptics": "^8.0.2",
    "@clerk/nextjs": "^7.2.3",
    "@electric-sql/pglite": "^0.4.4",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@phosphor-icons/react": "^2.1.10",
    "@slack/bolt": "^4.7.0",
    "@slack/web-api": "^7.15.0",
    "chokidar": "^5.0.0",
    "gbrain": "git+https://github.com/garrytan/gbrain.git#90c5d93fcebb94c9d1e3b31167f9760fbfe077a9",
    "googleapis": "^171.4.0",
    "gray-matter": "^4.0.3",
    "json5": "^2.2.3",
    "katex": "^0.16.45",
    "next": "16.2.3",
    "openai": "^6.34.0",
    "pdf-parse": "^2.4.5",
    "pgvector": "^0.2.1",
    "postgres": "^3.4.7",
    "qrcode": "^1.5.4",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-markdown": "^10.1.0",
    "rehype-katex": "^7.0.1",
    "rehype-sanitize": "^6.0.0",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "remark-wiki-link": "^2.0.1",
    "shiki": "^4.0.2",
    "telegram": "^2.26.22",
    "ws": "^8.20.0",
    "yauzl": "^3.3.0"
  },
  "overrides": {
    "gbrain": {
      "@electric-sql/pglite": "0.4.4"
    }
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^25",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/ws": "^8.18.1",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.3",
    "glob": "^13.0.6",
    "jsdom": "^29.0.2",
    "tailwindcss": "^4",
    "tsx": "^4.20.6",
    "typescript": "^6",
    "vitest": "^4.1.4"
  }
}
