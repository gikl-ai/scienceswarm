{
  "name": "scienceswarm",
  "version": "0.1.0",
  "private": true,
  "main": "desktop/main.mjs",
  "description": "ScienceSwarm — local-first research workspace. OpenClaw (manager agent) + OpenHands (execution agent) + gbrain (knowledge layer).",
  "license": "MIT",
  "author": "ScienceSwarm contributors",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gikl-ai/scienceswarm.git"
  },
  "homepage": "https://github.com/gikl-ai/scienceswarm#readme",
  "bugs": {
    "url": "https://github.com/gikl-ai/scienceswarm/issues"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "FRONTEND_HOST=${FRONTEND_HOST:-127.0.0.1} next dev --webpack -H ${FRONTEND_HOST:-127.0.0.1} -p $(npx tsx scripts/print-port.ts frontend)",
    "build": "next build",
    "build:standalone": "SCIENCESWARM_STANDALONE_BUILD=1 next build --webpack && node scripts/prepare-standalone-build.mjs",
    "desktop:dev": "electron desktop/main.mjs",
    "desktop:install-runtime": "bash scripts/install-desktop-runtime-prereqs.sh",
    "prepare:desktop-package": "node scripts/prepare-desktop-package.mjs",
    "desktop:checksums": "node scripts/write-artifact-checksums.mjs",
    "desktop:dist": "npm run prepare:desktop-package && electron-builder --projectDir .desktop-package/app --dir",
    "desktop:pack": "npm run prepare:desktop-package && electron-builder --projectDir .desktop-package/app",
    "desktop:pack:linux": "npm run prepare:desktop-package && electron-builder --projectDir .desktop-package/app --linux AppImage --publish never",
    "desktop:pack:mac": "npm run prepare:desktop-package && electron-builder --projectDir .desktop-package/app --mac dmg --publish never",
    "desktop:pack:win": "npm run prepare:desktop-package && electron-builder --projectDir .desktop-package/app --win nsis --publish never",
    "start": "./start.sh",
    "start:standalone": "node scripts/start-standalone.mjs",
    "lint": "eslint",
    "test": "vitest run",
    "test:fast": "vitest run --config vitest.fast.config.ts",
    "test:related": "node scripts/run-related-tests.mjs",
    "test:bench": "vitest bench --run",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit --pretty false -p tsconfig.typecheck.json",
    "python:quality": "./scripts/python-quality.sh",
    "doctor": "npx tsx scripts/doctor.ts",
    "smoke:local": "NODE_OPTIONS=--preserve-symlinks npx tsx scripts/smoke-local.ts",
    "connect-gbrain": "NODE_OPTIONS=--preserve-symlinks npx tsx scripts/connect-gbrain.ts",
    "install:gbrain": "NODE_OPTIONS=--preserve-symlinks npx tsx scripts/install-gbrain.ts",
    "setup:reset": "NODE_OPTIONS=--preserve-symlinks npx tsx scripts/reset-onboarding.ts",
    "migrate:chat-threads-openclaw": "NODE_OPTIONS=--preserve-symlinks npx tsx scripts/migrate-chat-threads-openclaw.ts",
    "bench:chat-hi": "NODE_OPTIONS=--preserve-symlinks npx tsx scripts/benchmark-chat-hi.ts",
    "import-pdfs": "npx tsx scripts/import-pdfs.ts",
    "radar:run": "NODE_OPTIONS=--preserve-symlinks npx tsx scripts/run-research-radar.ts",
    "dream:run": "NODE_OPTIONS=--preserve-symlinks npx tsx scripts/run-dream-cycle.ts",
    "quality": "npm run test && npm run lint && npm run typecheck && npm run build && npm run design:drift:strict",
    "design:drift": "node --experimental-strip-types scripts/check-design-drift.ts",
    "design:drift:strict": "node --experimental-strip-types scripts/check-design-drift.ts --error"
  },
  "dependencies": {
    "@capacitor/camera": "^8.1.0",
    "@capacitor/cli": "^8.3.1",
    "@capacitor/core": "^8.3.1",
    "@capacitor/haptics": "^8.0.2",
    "@clerk/nextjs": "^7.2.7",
    "@electric-sql/pglite": "0.4.5",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@phosphor-icons/react": "^2.1.10",
    "@slack/bolt": "^4.7.1",
    "@slack/web-api": "^7.15.0",
    "chokidar": "^5.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "gbrain": "git+https://github.com/garrytan/gbrain.git#f718c595b3a382b2a9a6a1f6553448ad047b5e94",
    "googleapis": "^171.4.0",
    "gray-matter": "^4.0.3",
    "json5": "^2.2.3",
    "katex": "^0.16.45",
    "lucide-react": "^1.11.0",
    "next": "16.2.4",
    "next-themes": "^0.4.6",
    "openai": "^6.34.0",
    "pdf-parse": "^2.4.5",
    "pgvector": "^0.2.1",
    "postgres": "^3.4.7",
    "qrcode": "^1.5.4",
    "radix-ui": "^1.4.3",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-markdown": "^10.1.0",
    "rehype-katex": "^7.0.1",
    "rehype-sanitize": "^6.0.0",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "remark-wiki-link": "^2.0.1",
    "shiki": "^4.0.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "telegram": "^2.26.22",
    "ws": "^8.20.0",
    "yauzl": "^3.3.0"
  },
  "overrides": {
    "gbrain": {
      "@electric-sql/pglite": "0.4.5"
    }
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^25",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/ws": "^8.18.1",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.4",
    "glob": "^13.0.6",
    "jsdom": "^29.1.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^6",
    "vitest": "^4.1.5"
  },
  "build": {
    "appId": "ai.scienceswarm.desktop",
    "productName": "ScienceSwarm",
    "electronVersion": "41.3.0",
    "extraMetadata": {
      "main": "desktop/main.mjs"
    },
    "asar": true,
    "asarUnpack": [
      ".next/standalone/**"
    ],
    "npmRebuild": false,
    "files": [
      "**/*",
      "!desktop/ollama-models/**",
      "!desktop/**/*.gguf",
      "!desktop/**/blobs/**",
      "!desktop/**/manifests/**",
      "package.json"
    ],
    "directories": {
      "app": ".desktop-package/app",
      "buildResources": "desktop/build"
    },
    "mac": {
      "artifactName": "${productName}-${version}-mac-${arch}.${ext}",
      "target": [
        "dmg"
      ],
      "category": "public.app-category.productivity"
    },
    "win": {
      "artifactName": "${productName}-${version}-windows-${arch}.${ext}",
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "artifactName": "${productName}-${version}-linux-${arch}.${ext}",
      "target": [
        "AppImage"
      ],
      "category": "Office"
    }
  }
}
